# Server
PORT=4000
# Every 5 minutes by default. Example for every minute: * * * * *
SYNC_CRON=*/5 * * * *

# Shopify app credentials
SHOPIFY_API_KEY=your_public_api_key
SHOPIFY_API_SECRET=your_api_secret_key
# Optional aliases (same values as above if you use "client id/secret" naming):
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxx
PUBLIC_BASE_URL=https://your-public-url.ngrok-free.dev

# Webhook signature verification secret
SHOPIFY_WEBHOOK_SECRET=your_app_client_secret
